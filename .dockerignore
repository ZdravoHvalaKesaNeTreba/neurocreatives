# === Git ===
.git/
.github/

# === Python cache ===
__pycache__/
*.py[cod]
*$py.class
venv/
env/
ENV/
*.egg-info/
.mypy_cache/
.pytest_cache/

# === Database sessions / local DBs ===
*.session
*.db
*.sqlite

# === Environment files (secrets — передаются через --env-file) ===
.env
.env.*

# === IDE ===
.vscode/
.idea/
*.swp
*.swo

# === Downloads (монтируется как volume) ===
downloads/*
!downloads/.gitkeep

# === Documentation ===
*.md
*.sql

# === Backup / Archives ===
backups/
*.zip
*.tar.gz
*.backup
*.bak

# === Screenshots / large images in root ===
screenshot_scheduler.png

# === OS ===
.DS_Store
Thumbs.db

# === Docker configs (не нужны внутри образа) ===
Dockerfile
Dockerfile.*
docker-compose*.yml

# === Deploy scripts ===
deploy/

