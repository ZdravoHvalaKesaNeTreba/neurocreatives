# ===================================================
# Neurocreatives — Environment Variables
# Скопируйте в .env и заполните реальными значениями
# ===================================================

# --- Telegram API ---
# Получите на https://my.telegram.org
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# --- OpenAI API ---
# Получите на https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key

# --- Database (PostgreSQL на Yandex Cloud) ---
# Формат: postgresql://user:password@host:port/database?sslmode=verify-full&target_session_attrs=read-write
DATABASE_URL=postgresql://user1:PASSWORD@rc1b-XXXXX.mdb.yandexcloud.net:6432/db_neurocreatives?sslmode=verify-full&target_session_attrs=read-write

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Удалённый сервер с картинками (для локальной разработки / Docker) ---
# Если картинки хранятся на удалённом сервере, укажите его URL (без trailing slash).
# При отсутствии файла локально, картинки будут подтягиваться с этого URL.
# Пример: https://your-server.example.com
REMOTE_IMAGES_BASE_URL=

# --- Каналы Telegram (через запятую, без пробелов) ---
CHANNELS_TO_PARSE=GuerrillaMarketing,Durov,sostav
