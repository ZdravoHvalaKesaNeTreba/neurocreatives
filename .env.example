# Neurocreatives Environment Variables

# Telegram API
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# OpenAI API
OPENAI_API_KEY=your_openai_api_key

# Database
DATABASE_URL=postgresql+psycopg://user:password@host:port/database?sslmode=verify-full&target_session_attrs=read-write

# Server
HOST=0.0.0.0
PORT=8000
